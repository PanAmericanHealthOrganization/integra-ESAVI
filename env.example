# Variables de entorno para INTEGRA-ESAVI
# Copia este archivo como .env y configura los valores reales

# Keycloak Configuration
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=integra-esavi
VITE_KEYCLOAK_CLIENT_ID=integra-esavi-client

# API Configuration
VITE_INTEGRA_ESAVI_API_URL=http://localhost:3001/api
VITE_API_KEY=your-api-key-here

# ESAVI Configuration
VITE_ESAVI_GRAVE=true
VITE_ESAVI_DASHBOARD_TOKEN=token_ejemplo_1 