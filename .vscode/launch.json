{
    "version": "0.2.0",
    "configurations": [
      {
        "type": "node",
        "request": "launch",
        "name": "NestJS Debug con start:julio",
        "runtimeExecutable": "pnpm",
        "runtimeArgs": [
          "run",
          "start:julio"
        ],
        "args": [
          "${workspaceFolder}/src/main.ts"
        ],
        "cwd": "${workspaceFolder}",
        //"protocol": "inspector",
        "skipFiles": ["<node_internals>/**"],
        "outFiles": ["${workspaceFolder}/dist/**/*.js"]
      }
    ]
  }
  