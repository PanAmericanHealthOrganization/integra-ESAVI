# Imagen de desarrollo: React + Vite con HMR
# El código fuente se monta como volumen desde docker-compose.dev.yaml
FROM node:22-bookworm-slim

# corepack usa la versión de pnpm declarada en package.json (pnpm@9.12.1)
ENV COREPACK_ENABLE_DOWNLOAD_PROMPT=0
RUN corepack enable

WORKDIR /app

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml .npmrc ./
RUN pnpm install

COPY . .

EXPOSE 5173

# --host 0.0.0.0 para que el dev server sea accesible fuera del contenedor
CMD ["pnpm", "start:dev", "--host", "0.0.0.0"]
